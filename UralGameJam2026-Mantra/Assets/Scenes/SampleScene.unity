    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435, \u0442\u0435\u043C \u0431\u043E\u043B\u044C\u0448\u0435
    \u0448\u0430\u043D\u0441, \u0447\u0442\u043E \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436
    \u043D\u0430\u043D\u0435\u0441\u0451\u0442 \u0431\u043E\u043B\u044C\u0448\u0435
    \u0443\u0440\u043E\u043D\u0430."
